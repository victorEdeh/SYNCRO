# =============================================================================
# Synchro Backend – Environment Variables
# Copy this file to .env and fill in your values.
# See docs/environment-variables.md for the full variable matrix.
# =============================================================================

# --- Server ---
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info

# --- Supabase (required) ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# --- Admin ---
# REQUIRED. Use a strong random value in production.
ADMIN_API_KEY=change-me-in-production

# --- Blockchain / Stellar ---
# Required only if blockchain sync is enabled.
SOROBAN_CONTRACT_ADDRESS=your_contract_address_here
STELLAR_NETWORK_URL=https://soroban-testnet.stellar.org
# For mainnet: STELLAR_NETWORK_URL=https://soroban-mainnet.stellar.org
STELLAR_SECRET_KEY=<your-stellar-secret-key>

# --- Push Notifications (Web Push / VAPID) ---
# Required only if push notifications are enabled.
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=<your-vapid-public-key>
VAPID_PRIVATE_KEY=<your-vapid-private-key>
VAPID_SUBJECT=mailto:noreply@synchro.app
