#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Validate dependencies if package.json changed
if git diff --cached --name-only | grep -q "client/package.json"; then
  echo "📦 Validating client dependencies..."
  cd client && node scripts/validate-deps.js || exit 1
  cd ..
fi

if git diff --cached --name-only | grep -q "backend/package.json"; then
  echo "📦 Checking backend package.json for 'latest' versions..."
  if grep -q '"latest"' backend/package.json; then
    echo "❌ Error: 'latest' version found in backend/package.json"
    echo "Please specify an exact version or semver range."
    exit 1
  fi
fi

# Run lint-staged
npx lint-staged --config backend/.lintstagedrc.json --cwd backend
npx lint-staged --config client/.lintstagedrc.json --cwd client

