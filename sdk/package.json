{
  "name": "@syncro/sdk",
  "version": "1.1.0",
  "description": "Official SDK for the SYNCRO Subscription Management Platform",
  "packageManager": "npm@10.9.2",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./errors": {
      "import": "./dist/errors.js",
      "types": "./dist/errors.d.ts"
    },
    "./zk": {
      "import": "./dist/zk/index.js",
      "types": "./dist/zk/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "jest",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run build"
  },
  "keywords": [
    "syncro",
    "subscriptions",
    "sdk"
  ],
  "author": "SYNCRO",
  "license": "MIT",
  "dependencies": {
    "@syncro/shared": "file:../shared",
    "axios": "^1.13.5",
    "events": "^3.3.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
